#!/bin/sh

# Copyright (C) 2006 OpenWrt.org
# Copyright 2022-2026 sirpdboy <herboy2008@gmail.com>
#
# 适配 ImmortalWrt 25.12 修复：
# 1. config_t_get 中 ${ret:=${4}} -> ${ret:-${4}}
# 2. 所有 eq 比较改为 -eq
# 3. 设备 ID 提取使用 grep -oE '[0-9]+' 避免拆分多位数
# 4. 时长重置改用 date +%Y%m%d / %Y%W / %Y%m 直接比较，避免 date -d
# 5. 变量引用添加双引号避免分词
#
# [新增] 支持 multi_period 模式：最多3个独立时段，每个时段独立计时

NAME=timecontrol
LOG_FILE="/var/log/timecontrol.log"
DEBUG=1

# 时长数据库目录
DURATION_DIR="/var/lib/timecontrol"
DURATION_DB="$DURATION_DIR/duration.db"
CONNECTION_LOG="$DURATION_DIR/connections.log"
# [新增] 多时段时长数据库：target,period,last_connect,total_used,last_reset
PERIOD_DURATION_DB="$DURATION_DIR/period_duration.db"

# 状态文件
IDLIST="/var/$NAME.idlist"
STATUS_DB="$DURATION_DIR/status.db"

# 初始化目录
init_dirs() {
    mkdir -p "$DURATION_DIR"
    touch "$DURATION_DB" "$CONNECTION_LOG" "$STATUS_DB" "$PERIOD_DURATION_DB" 2>/dev/null
}

# 日志函数
dbg() {
    [ "$DEBUG" -eq 1 ] && {
        local d="$(date '+%Y-%m-%d %H:%M:%S')"
        echo "[$d] CTRL-DEBUG: $@" >> "$LOG_FILE"
    }
}

info() {
    local d="$(date '+%Y-%m-%d %H:%M:%S')"
    echo "[$d] CTRL-INFO: $@" >> "$LOG_FILE"
}

# 配置文件读取
config_t_get() {
    local index=${3:-0}
    local ret=$(uci -q get "${NAME}.@${1}[${index}].${2}")
    echo "${ret:-${4}}"
}

# 获取启用设备（修复：匹配完整数字 ID）
get_enabled_devices() {
    uci show "$NAME" 2>/dev/null | grep "enable='1'" | grep "device" | grep -oE '\[[0-9]+\]' | grep -oE '[0-9]+' | sort -n
}

# 时间检查函数
is_time_in_range() {
    local start_time=$1
    local end_time=$2
    local current_time=$(date +%H:%M)

    if [ "$start_time" = "$end_time" ]; then
        return 0
    elif [ "$start_time" \< "$end_time" ]; then
        [ "$current_time" \> "$start_time" ] && [ "$current_time" \< "$end_time" ] && return 0
    else
        [ "$current_time" \> "$start_time" ] || [ "$current_time" \< "$end_time" ] && return 0
    fi
    return 1
}

is_weekday_in_range() {
    local configured_weekdays=$1
    local current_weekday=$(date +%u)

    [ "$configured_weekdays" = "0" ] && return 0
    
    for ww in $(echo "$configured_weekdays" | sed 's/,/ /g'); do
        [ "$current_weekday" = "$ww" ] && return 0
    done
    return 1
}

# ============= 原有单时段时长管理 =============
record_connection_time() {
    local target="$1"
    local action="$2"
    local timestamp=$(date +%s)
    
    echo "$timestamp,$target,$action" >> "$CONNECTION_LOG"
    
    if [ "$action" = "connect" ]; then
        if ! grep -q "^$target," "$DURATION_DB" 2>/dev/null; then
            echo "$target,$timestamp,0,0" >> "$DURATION_DB"
            dbg "初始化时长: $target"
        fi
    elif [ "$action" = "disconnect" ]; then
        if grep -q "^$target," "$DURATION_DB" 2>/dev/null; then
            local last_connect=$(grep "^$target," "$DURATION_DB" | cut -d',' -f2)
            local total_used=$(grep "^$target," "$DURATION_DB" | cut -d',' -f3)
            local last_reset=$(grep "^$target," "$DURATION_DB" | cut -d',' -f4)
            
            local session_duration=$((timestamp - last_connect))
            local new_total=$((total_used + session_duration))
            
            sed -i "/^$target,/d" "$DURATION_DB"
            echo "$target,$timestamp,$new_total,$last_reset" >> "$DURATION_DB"
        fi
    fi
}

get_connection_time() {
    local target="$1"
    local current_time=$(date +%s)
    
    if grep -q "^$target," "$DURATION_DB" 2>/dev/null; then
        local last_connect=$(grep "^$target," "$DURATION_DB" | cut -d',' -f2)
        local total_used=$(grep "^$target," "$DURATION_DB" | cut -d',' -f3)
        
        if tail -n 5 "$CONNECTION_LOG" 2>/dev/null | grep -q "^[0-9]*,$target,connect$"; then
            local session_duration=$((current_time - last_connect))
            total_used=$((total_used + session_duration))
        fi
        
        echo "$total_used"
    else
        echo "0"
    fi
}

# 重置检查（原有）
should_reset_duration() {
    local target="$1"
    local reset_cycle="$2"
    local reset_file="$DURATION_DIR/last_reset_$target"
    
    [ ! -f "$reset_file" ] && return 0
    
    local last_reset=$(cat "$reset_file" 2>/dev/null)
    local current_date=$(date +%Y%m%d)
    local current_week=$(date +%Y%W)
    local current_month=$(date +%Y%m)
    
    case "$reset_cycle" in
        "daily")
            [ "$last_reset" != "$current_date" ]
            ;;
        "weekly")
            [ "$last_reset" != "$current_week" ]
            ;;
        "monthly")
            [ "$last_reset" != "$current_month" ]
            ;;
        *)
            false
            ;;
    esac
}

reset_duration_counter() {
    local target="$1"
    local reset_cycle="$2"
    local current_time=$(date +%s)
    local reset_value=$(date +%Y%m%d)
    
    case "$reset_cycle" in
        "weekly")  reset_value=$(date +%Y%W) ;;
        "monthly") reset_value=$(date +%Y%m) ;;
    esac
    
    sed -i "/^$target,/d" "$DURATION_DB" 2>/dev/null
    echo "$target,$current_time,0,$current_time" >> "$DURATION_DB"
    echo "$reset_value" > "$DURATION_DIR/last_reset_$target"
    
    info "重置时长: $target (周期: $reset_cycle)"
}

# ============= [新增] 多时段时长管理 =============

# 获取某个时段已用秒数
get_period_used() {
    local target="$1"
    local period="$2"
    local current_time=$(date +%s)
    local total_used=0
    
    if grep -q "^$target,$period," "$PERIOD_DURATION_DB" 2>/dev/null; then
        local last_connect=$(grep "^$target,$period," "$PERIOD_DURATION_DB" | cut -d',' -f3)
        total_used=$(grep "^$target,$period," "$PERIOD_DURATION_DB" | cut -d',' -f4)
        # 如果 last_connect > 0，表示当前处于连接状态，累加时间差
        if [ -n "$last_connect" ] && [ "$last_connect" -gt 0 ]; then
            local session=$((current_time - last_connect))
            [ "$session" -gt 0 ] && total_used=$((total_used + session))
        fi
    fi
    echo "$total_used"
}

# 更新时段状态：allow 或 deny
update_period_state() {
    local target="$1"
    local period="$2"
    local action="$3"   # "allow" 或 "deny"
    local current_time=$(date +%s)
    
    # 查找是否存在记录
    if grep -q "^$target,$period," "$PERIOD_DURATION_DB" 2>/dev/null; then
        local last_connect=$(grep "^$target,$period," "$PERIOD_DURATION_DB" | cut -d',' -f3)
        local total_used=$(grep "^$target,$period," "$PERIOD_DURATION_DB" | cut -d',' -f4)
        local last_reset=$(grep "^$target,$period," "$PERIOD_DURATION_DB" | cut -d',' -f5)
        
        if [ "$action" = "allow" ]; then
            # 如果之前是断开状态（last_connect == 0），则开始计时
            if [ -z "$last_connect" ] || [ "$last_connect" -eq 0 ]; then
                last_connect=$current_time
            fi
            # 如果之前已是连接状态，则更新 last_connect 为当前时间（连续计时）
            # 但为了精确，我们只在允许时累加会话时长，这里不累加，由 get_period_used 动态计算
            sed -i "/^$target,$period,/d" "$PERIOD_DURATION_DB"
            echo "$target,$period,$last_connect,$total_used,$last_reset" >> "$PERIOD_DURATION_DB"
        else
            # deny: 断开连接，如果之前是连接状态，则累计时长（但 get_period_used 会动态累加，我们这里只将 last_connect 置0）
            if [ -n "$last_connect" ] && [ "$last_connect" -gt 0 ]; then
                # 累加从 last_connect 到现在的时长
                local session=$((current_time - last_connect))
                [ "$session" -gt 0 ] && total_used=$((total_used + session))
                last_connect=0
            fi
            sed -i "/^$target,$period,/d" "$PERIOD_DURATION_DB"
            echo "$target,$period,$last_connect,$total_used,$last_reset" >> "$PERIOD_DURATION_DB"
        fi
    else
        # 不存在记录，创建新记录
        if [ "$action" = "allow" ]; then
            echo "$target,$period,$current_time,0,0" >> "$PERIOD_DURATION_DB"
        else
            echo "$target,$period,0,0,0" >> "$PERIOD_DURATION_DB"
        fi
    fi
}

# 重置某个时段计数器
reset_period_counter() {
    local target="$1"
    local period="$2"
    local reset_cycle="$3"
    local current_time=$(date +%s)
    local reset_value=$(date +%Y%m%d)
    
    case "$reset_cycle" in
        "weekly")  reset_value=$(date +%Y%W) ;;
        "monthly") reset_value=$(date +%Y%m) ;;
    esac
    
    sed -i "/^$target,$period,/d" "$PERIOD_DURATION_DB" 2>/dev/null
    echo "$target,$period,0,0,$current_time" >> "$PERIOD_DURATION_DB"
    # 存储该时段的重置标记（独立存储）
    echo "$reset_value" > "$DURATION_DIR/last_reset_${target}_period${period}"
    info "重置时段$period 时长: $target (周期: $reset_cycle)"
}

# 检查是否需要重置某个时段
should_reset_period() {
    local target="$1"
    local period="$2"
    local reset_cycle="$3"
    local reset_file="$DURATION_DIR/last_reset_${target}_period${period}"
    
    [ ! -f "$reset_file" ] && return 0
    
    local last_reset=$(cat "$reset_file" 2>/dev/null)
    local current_date=$(date +%Y%m%d)
    local current_week=$(date +%Y%W)
    local current_month=$(date +%Y%m)
    
    case "$reset_cycle" in
        "daily")
            [ "$last_reset" != "$current_date" ]
            ;;
        "weekly")
            [ "$last_reset" != "$current_week" ]
            ;;
        "monthly")
            [ "$last_reset" != "$current_month" ]
            ;;
        *)
            false
            ;;
    esac
}

# ============= 主检查函数 =============
check_device_control() {
    local id="$1"
    local target=$(config_t_get device mac "$id")
    local time_mode=$(config_t_get device time_mode "$id" "period")
    local weekdays=$(config_t_get device week "$id" "0")
    
    # 检查星期
    is_weekday_in_range "$weekdays" || {
        dbg "星期不允许: $target"
        return 1
    }
    
    case "$time_mode" in
        "period")
            local start_time=$(config_t_get device timestart "$id" "00:00")
            local end_time=$(config_t_get device timeend "$id" "00:00")
            is_time_in_range "$start_time" "$end_time" || {
                dbg "时间段外: $target ($start_time-$end_time)"
                return 1
            }
            dbg "时间段内: $target"
            return 0
            ;;
            
        "duration")
            local duration=$(config_t_get device duration "$id" "60")
            local reset_cycle=$(config_t_get device reset_cycle "$id" "daily")
            
            if should_reset_duration "$target" "$reset_cycle"; then
                reset_duration_counter "$target" "$reset_cycle"
            fi
            
            local last_action=$(grep ",$target," "$CONNECTION_LOG" 2>/dev/null | tail -1 | cut -d',' -f3)
            if [ "$last_action" != "connect" ]; then
                record_connection_time "$target" "connect"
            fi
            
            local used_seconds=$(get_connection_time "$target")
            local used_minutes=$((used_seconds / 60))
            local max_minutes=$duration
            
            dbg "时长检查: $target 已用=${used_minutes}分钟, 限制=${max_minutes}分钟"
            
            if [ "$used_minutes" -ge "$max_minutes" ]; then
                dbg "已超时: $target"
                return 1
            fi
            dbg "未超时: $target"
            return 0
            ;;
            
        "combined")
            local start_time=$(config_t_get device timestart "$id" "00:00")
            local end_time=$(config_t_get device timeend "$id" "00:00")
            local use_duration=$(config_t_get device use_duration "$id" "0")
            
            is_time_in_range "$start_time" "$end_time" || {
                dbg "时间段外: $target"
                return 1
            }
            
            if [ "$use_duration" = "1" ]; then
                local duration=$(config_t_get device duration "$id" "60")
                local reset_cycle=$(config_t_get device reset_cycle "$id" "daily")
                
                if should_reset_duration "$target" "$reset_cycle"; then
                    reset_duration_counter "$target" "$reset_cycle"
                fi
                
                local last_action=$(grep ",$target," "$CONNECTION_LOG" 2>/dev/null | tail -1 | cut -d',' -f3)
                if [ "$last_action" != "connect" ]; then
                    record_connection_time "$target" "connect"
                fi
                
                local used_seconds=$(get_connection_time "$target")
                local used_minutes=$((used_seconds / 60))
                local max_minutes=$duration
                
                if [ "$used_minutes" -ge "$max_minutes" ]; then
                    dbg "时间段内但已超时: $target"
                    return 1
                fi
            fi
            
            dbg "时间段内允许: $target"
            return 0
            ;;
            
        # ============ [新增] 多时段控制 ============
        "multi_period")
            local reset_cycle=$(config_t_get device reset_cycle "$id" "daily")
            local in_any_period=0
            
            # 遍历3个时段
            for p in 1 2 3; do
                local start=$(config_t_get device "period${p}_start" "$id" "")
                local end=$(config_t_get device "period${p}_end" "$id" "")
                local dur=$(config_t_get device "period${p}_duration" "$id" "")
                [ -z "$start" ] && continue  # 未配置则跳过
                
                if is_time_in_range "$start" "$end"; then
                    in_any_period=1
                    # 检查该时段是否需要重置
                    if should_reset_period "$target" "$p" "$reset_cycle"; then
                        reset_period_counter "$target" "$p" "$reset_cycle"
                    fi
                    
                    # 获取当前已用分钟数（秒数转分钟）
                    local used_seconds=$(get_period_used "$target" "$p")
                    local used_minutes=$((used_seconds / 60))
                    
                    dbg "时段$p 检查: $target 已用=${used_minutes}分钟, 限制=${dur}分钟"
                    
                    if [ "$used_minutes" -ge "$dur" ]; then
                        dbg "时段$p 已超时: $target"
                        # 将该时段状态置为 deny（避免继续累加）
                        update_period_state "$target" "$p" "deny"
                        return 1
                    else
                        # 未超时，将状态置为 allow（开始或继续计时）
                        update_period_state "$target" "$p" "allow"
                        # 如果设备当前被阻止，需要允许，由上层 update_device_status 处理
                        # 这里返回0表示允许
                        dbg "时段$p 允许: $target"
                        return 0
                    fi
                else
                    # 不在该时段，确保状态为 deny（不累计时间）
                    update_period_state "$target" "$p" "deny"
                fi
            done
            
            # 所有时段都不匹配
            if [ "$in_any_period" -eq 0 ]; then
                dbg "不在任何时段: $target"
            fi
            return 1
            ;;
            
        *)
            # 默认时间段控制
            local start_time=$(config_t_get device timestart "$id" "00:00")
            local end_time=$(config_t_get device timeend "$id" "00:00")
            is_time_in_range "$start_time" "$end_time"
            return $?
            ;;
    esac
}

# 更新设备状态
update_device_status() {
    local id="$1"
    local should_allow="$2"  # 0=允许, 1=禁止
    local target=$(config_t_get device mac "$id")
    local comment=$(config_t_get device comment "$id" "设备$id")
    
    # 检查当前状态
    local current_blocked=0
    if [ -f "$IDLIST" ] && grep -q "!${id}!" "$IDLIST" 2>/dev/null; then
        current_blocked=1
    fi
    
    dbg "设备状态: $target, 应该允许=$should_allow, 当前阻止=$current_blocked"
    
    if [ "$should_allow" -eq 0 ]; then
        if [ "$current_blocked" -eq 1 ]; then
            dbg "解除阻止: $target"
            timecontrol del "$id"
            sed -i "/!$id!/d" "$IDLIST" 2>/dev/null
            info "允许上网: $comment ($target)"
            # 原有单时段记录断开（仅用于兼容）
            record_connection_time "$target" "disconnect"
        fi
    else
        if [ "$current_blocked" -eq 0 ]; then
            dbg "添加阻止: $target"
            timecontrol add "$id"
            if ! grep -q "!$id!" "$IDLIST" 2>/dev/null; then
                echo "!$id!" >> "$IDLIST"
            fi
            info "阻止上网: $comment ($target)"
            record_connection_time "$target" "disconnect"
        fi
    fi
}


# ============= 主循环（流量感知版） =============
main_loop() {
    info "时间控制守护进程启动"
    init_dirs
    read_traffic_config  # 读取配置
    info "流量感知: $([ "$TRAFFIC_ENABLED" = "1" ] && echo "启用" || echo "禁用")"
    info "阈值: ${TRAFFIC_THRESHOLD_KB}KB, 连续次数: ${TRAFFIC_CONSECUTIVE}, 轮询间隔: ${TRAFFIC_POLL_INTERVAL}s"
    
    while :; do
        dbg "开始检查设备"
        count=$(uci show "$NAME" 2>/dev/null | grep "enable='1'" | grep "device" | grep -oE '\[[0-9]+\]' | grep -oE '[0-9]+' | sort -n | wc -l)
        if [ "${count:-0}" -eq 0 ]; then
            timecontrol stop
            break
        fi
        
        for id in $(get_enabled_devices); do
            local target=$(config_t_get device mac "$id")
            local allow=$(check_device_control "$id"; echo $?)   # 0允许，1禁止
            
            # 更新防火墙规则
            if [ "$allow" -eq 0 ]; then
                update_device_status "$id" 0
            else
                update_device_status "$id" 1
            fi
            
            # 如果设备被禁止上网，无需流量检测（已经断开计时）
            if [ "$allow" -ne 0 ]; then
                continue
            fi
            
            # 如果流量感知未启用，则不做额外处理（计时由 check_device_control 中的 record_connection_time 管理）
            if [ "$TRAFFIC_ENABLED" = "0" ]; then
                continue
            fi
            
            # === 流量感知逻辑 ===
            local is_active=$(update_traffic_state "$target")
            local current_conn=$(grep ",$target," "$CONNECTION_LOG" 2>/dev/null | tail -1 | cut -d',' -f3)
            
            if [ "$is_active" = "1" ]; then
                # 活跃，若未连接则开始计时
                if [ "$current_conn" != "connect" ]; then
                    dbg "设备 $target 流量活跃，开始计时"
                    record_connection_time "$target" "connect"
                fi
            else
                # 不活跃，若已连接则暂停计时
                if [ "$current_conn" = "connect" ]; then
                    dbg "设备 $target 流量不活跃，暂停计时"
                    record_connection_time "$target" "disconnect"
                fi
            fi
        done
        
        # 使用配置的轮询间隔
        sleep "${TRAFFIC_POLL_INTERVAL:-30}"
    done
}

# 启动
main_loop
